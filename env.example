"""
Генерация заданий и проверка ответов через ИИ (OpenAI / YandexGPT).
Все промпты строго соответствуют ФГОС РФ.
"""
import json
import re
import logging
from openai import AsyncOpenAI

from config import OPENAI_API_KEY, AI_PROVIDER

logger = logging.getLogger(__name__)

client = AsyncOpenAI(api_key=OPENAI_API_KEY) if OPENAI_API_KEY else None


# ─── Системный промпт для генерации заданий ────────────────────────────────

TASK_SYSTEM_PROMPT = """Ты — опытный российский школьный учитель и методист.
Твоя задача — создавать учебные задания строго по программе ФГОС РФ.

ПРАВИЛА:
1. Задания должны точно соответствовать учебной программе для указанного класса.
2. Используй терминологию из официальных учебников Министерства просвещения РФ.
3. Задания должны быть чёткими, однозначными и иметь один правильный ответ.
4. Для математики и физики используй задачи из банка ФИПИ.
5. Для иностранных языков опирайся на учебники Spotlight, Starlight, Horizonte.
6. Никогда не давай ответ напрямую — только наводящие вопросы и подсказки.
7. Формулировки адаптируй под возраст: для 2-4 класса — простые слова и образы,
   для 9-11 — академический стиль.
8. ЗАПРЕЩЕНО: политический контент, личные данные, нецензурные слова.

Отвечай ТОЛЬКО в формате JSON без лишнего текста."""


# ─── Промпт для генерации задания ─────────────────────────────────────────

def build_task_prompt(subject: str, grade: str, difficulty: str) -> str:
    difficulty_map = {
        "easy": "базовый уровень, стандартные задачи из учебника",
        "medium": "повышенный уровень, задачи для олимпиад внутришкольного уровня",
        "hard": "высокий уровень, задачи со звёздочкой, подготовка к ОГЭ/ЕГЭ",
    }
    grade_int = int(grade)
    exam_hint = ""
    if grade_int in (9,):
        exam_hint = "Учти требования ОГЭ. "
    elif grade_int in (10, 11):
        exam_hint = "Учти требования ЕГЭ. "

    return f"""Сгенерируй одно учебное задание по предмету "{subject}" для {grade} класса.
Уровень сложности: {difficulty_map.get(difficulty, 'базовый')}.
{exam_hint}

Верни JSON:
{{
  "task": "Полный текст задания для ученика (1-3 предложения)",
  "topic": "Название темы по ФГОС",
  "correct_answer": "Правильный ответ (краткий)",
  "answer_type": "number|fraction|text|choice",
  "hint1": "Первая подсказка — наводящий вопрос",
  "hint2": "Вторая подсказка — теоретическое правило",
  "explanation": "Краткое объяснение для ученика (2-3 предложения), если ответ неверный"
}}"""


# ─── Промпт для проверки ответа ───────────────────────────────────────────

def build_check_prompt(task: str, correct_answer: str, user_answer: str,
                        grade: str, subject: str) -> str:
    return f"""Ты проверяешь ответ ученика {grade} класса по предмету "{subject}".

Задание: {task}
Правильный ответ: {correct_answer}
Ответ ученика: {user_answer}

Проверь ответ ученика. Учитывай:
- Допустимы эквивалентные формы записи (1/2 = 0.5, два = 2)
- Для текстовых ответов — смысл важнее точной формулировки
- Если в ответе есть орфографическая ошибка, укажи это мягко
- НЕ давай правильный ответ, если ученик ошибся — только направляй

Верни JSON:
{{
  "is_correct": true/false,
  "spelling_note": "замечание об орфографии или null",
  "feedback": "Краткая реакция бота (1 предложение, без правильного ответа если неверно)"
}}"""


# ─── Основные функции ─────────────────────────────────────────────────────

async def generate_task(subject: str, grade: str, difficulty: str) -> dict:
    """Генерация задания через AI."""
    if not client:
        return _fallback_task(subject, grade, difficulty)

    try:
        prompt = build_task_prompt(subject, grade, difficulty)
        response = await client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[
                {"role": "system", "content": TASK_SYSTEM_PROMPT},
                {"role": "user", "content": prompt}
            ],
            temperature=0.7,
            max_tokens=600,
        )
        raw = response.choices[0].message.content
        # Очистка от markdown-блоков
        clean = re.sub(r"```(?:json)?|```", "", raw).strip()
        return json.loads(clean)
    except Exception as e:
        logger.error(f"AI task generation error: {e}")
        return _fallback_task(subject, grade, difficulty)


async def check_answer(task: str, correct_answer: str,
                        user_answer: str, grade: str, subject: str) -> dict:
    """Проверка ответа ученика через AI."""
    if not client:
        return _fallback_check(correct_answer, user_answer)

    try:
        prompt = build_check_prompt(task, correct_answer, user_answer, grade, subject)
        response = await client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[
                {"role": "system", "content": TASK_SYSTEM_PROMPT},
                {"role": "user", "content": prompt}
            ],
            temperature=0.3,
            max_tokens=300,
        )
        raw = response.choices[0].message.content
        clean = re.sub(r"```(?:json)?|```", "", raw).strip()
        return json.loads(clean)
    except Exception as e:
        logger.error(f"AI check error: {e}")
        return _fallback_check(correct_answer, user_answer)


async def get_encouragement(name: str, streak: int) -> str:
    """Мотивирующее сообщение при серии правильных ответов."""
    messages = [
        f"Отличная работа, {name}! 🔥 Серия {streak} правильных ответов!",
        f"Ты в ударе, {name}! 🚀 Уже {streak} подряд — так держать!",
        f"Великолепно, {name}! ⭐ {streak} правильных ответов подряд — ты настоящий эрудит!",
    ]
    import random
    return random.choice(messages)


# ─── Заглушки при отсутствии API ──────────────────────────────────────────

def _fallback_task(subject: str, grade: str, difficulty: str) -> dict:
    """Резервные задания при недоступности AI."""
    fallbacks = {
        "📐 Математика": {
            "task": "Мама купила торт и разделила его на 8 равных частей. Петя съел 3 куска. Какую часть торта съел Петя? (Ответ напиши дробью)",
            "topic": "Обыкновенные дроби",
            "correct_answer": "3/8",
            "answer_type": "fraction",
            "hint1": "На сколько частей разделили торт? Сколько частей взял Петя?",
            "hint2": "Вспомни определение дроби: числитель — это части, которые взяли, знаменатель — всего частей.",
            "explanation": "Торт разделён на 8 частей — это знаменатель. Петя съел 3 части — это числитель. Ответ: 3/8."
        },
        "📝 Русский язык": {
            "task": "Вставь пропущенную букву: «Соба_ка бежала по дорожке». Объясни выбор.",
            "topic": "Непроверяемые написания (словарные слова)",
            "correct_answer": "собака",
            "answer_type": "text",
            "hint1": "Можно ли проверить эту букву ударением или однокоренным словом?",
            "hint2": "Некоторые слова нужно запомнить — они называются словарными словами.",
            "explanation": "«Собака» — словарное слово. Букву «о» в первом слоге нельзя проверить — её нужно запомнить."
        },
        "🇬🇧 Английский язык": {
            "task": "Переведи предложение на английский язык: «Я хожу в школу каждый день.»",
            "topic": "Present Simple (настоящее простое время)",
            "correct_answer": "I go to school every day.",
            "answer_type": "text",
            "hint1": "Какое время используется для регулярных действий? Что такое Present Simple?",
            "hint2": "Формула: I/You/We/They + глагол без изменений. Слово every day — признак Present Simple.",
            "explanation": "Регулярное действие → Present Simple. Подлежащее I + глагол go + дополнение to school + обстоятельство every day."
        },
    }
    default = fallbacks.get(subject, fallbacks["📐 Математика"])
    return default


def _fallback_check(correct_answer: str, user_answer: str) -> dict:
    """Простая проверка ответа без AI."""
    normalized_correct = correct_answer.strip().lower().replace(" ", "")
    normalized_user = user_answer.strip().lower().replace(" ", "")
    is_correct = normalized_correct == normalized_user
    return {
        "is_correct": is_correct,
        "spelling_note": None,
        "feedback": "Верно! Молодец! 🎉" if is_correct else "Не совсем. Подумай ещё!"
    }
